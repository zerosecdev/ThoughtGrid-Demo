.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key

# Build Outputs
dist/
build/
out/
.next/
.nuxt/

# Database & Uploads
uploads/
data/pg_data/
data/redis_data/
*.sqlite3

# OS Files
.DS_Store
Thumbs.db